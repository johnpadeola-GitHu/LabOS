# LabOS — environment variables
# Copy this file to .env.local and fill in your values for local development.
# NEVER commit .env.local to GitHub.
#
# In Cloudflare Pages: Settings → Environment Variables → Add these two.
# Leave blank to run in local demo mode (no backend required).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
